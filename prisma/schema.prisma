// Research Navigator Database Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Authentication & Users
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(STUDENT)
  department    String?
  designation   String?
  
  accounts      Account[]
  sessions      Session[]
  facultyProfile FacultyProfile?
  proposals     Proposal[]
  labsAsPi      Lab[]     @relation("LabPI")
  labsAsAssociate Lab[]   @relation("LabAssociate")
  labsAsAssistant Lab[]   @relation("LabAssistant")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  STUDENT
  FACULTY
  ADMIN
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// Faculty Profile
model FacultyProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  publications  Int      @default(0)
  hIndex        Int      @default(0)
  citations     Int      @default(0)
  keywords      String[] // Research domains
  pastFunding   Json?    // Array of past funding details
  domainVector  Float[]  // Embedding vector for semantic matching
  
  relevanceScores RelevanceScore[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Funding Calls (from attachment)
model FundingCall {
  id                  String   @id @default(cuid())
  agency              String
  title               String
  description         String?
  deadline            DateTime
  domainKeywords      String[]
  instituteEligibility String[]
  piEligibility       String?
  budgetMin           Float?
  budgetMax           Float?
  url                 String?
  
  relevanceScores RelevanceScore[]
  proposals       Proposal[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([deadline])
  @@index([agency])
}

// AI-Generated Relevance Scores
model RelevanceScore {
  id                String   @id @default(cuid())
  
  facultyId         String
  faculty           FacultyProfile @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  
  callId            String
  call              FundingCall @relation(fields: [callId], references: [id], onDelete: Cascade)
  
  score             Float    // 0-100
  domainSimilarity  Float
  publicationMatch  Float
  eligibilityStatus Boolean
  recommendation    String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([facultyId, callId])
  @@index([score])
}

// Research Labs
model Lab {
  id              String   @id @default(cuid())
  labName         String
  seedAmount      Float
  
  piId            String
  pi              User     @relation("LabPI", fields: [piId], references: [id])
  
  associateId     String?
  associate       User?    @relation("LabAssociate", fields: [associateId], references: [id])
  
  assistantId     String?
  assistant       User?    @relation("LabAssistant", fields: [assistantId], references: [id])
  
  sugCount        Int      @default(0) // Suggested UG students
  pgCount         Int      @default(0) // PG students
  labScore        Float    @default(0)
  
  roadmap         Json?    // Research roadmap
  outputs         Json?    // Publications, patents, etc.
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Proposals
model Proposal {
  id            String   @id @default(cuid())
  
  callId        String
  call          FundingCall @relation(fields: [callId], references: [id])
  
  facultyId     String
  faculty       User     @relation(fields: [facultyId], references: [id])
  
  title         String
  methodology   String?
  budget        Float?
  ganttJson     Json?    // Gantt chart data
  score         Float    @default(0)
  
  status        ProposalStatus @default(DRAFT)
  aiEvaluation  Json?    // AI feedback
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([status])
}

enum ProposalStatus {
  DRAFT
  UNDER_REVIEW
  SUBMITTED
  APPROVED
  REJECTED
}
